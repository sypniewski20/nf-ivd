params {

    // =====================================================
    // INPUT
    // =====================================================
    input_type      = 'fastq'      // fastq | bam
    samplesheet     = null

    // =====================================================
    // RUN MODE
    // =====================================================
    run_mode        = 'germline'   // germline | tumor_only | tumor_normal | calibration

    // =====================================================
    // REFERENCES
    // =====================================================
    fasta           = null
    fasta_dir       = null
    bed             = null
    strat_dir       = null        // GIAB stratification beds directory

    // =====================================================
    // GERMLINE / DRAGSTR SETTINGS
    // =====================================================
    seq_type            = 'WGS'      // WGS | WES
    calling_mode        = 'single'   // single | cohort
    interval_padding    = 150
    str_table           = null

    // DRAGSTR is mandatory (clinical equivalence to DRAGEN)
    dragen_mode         = true

    // Global GATK enforcement (applies to ALL HC calls)
    GATK_GLOBAL_ARGS = """
        --dragen-mode true
        --native-pair-hmm-threads 1
        --standard-min-confidence-threshold-for-calling 20
    """

    // =====================================================
    // TRUTH REGISTRY (clinical benchmarking)
    // =====================================================
    truth = [

        HG002: [
            vcf: "deployment/reference/truth/HG002_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG002_GRCh38_1_22_v4.2.1_benchmark_noinconsistent.bed"
        ],

        HG003: [
            vcf: "deployment/reference/truth/HG003_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG003_GRCh38_1_22_v4.2.1_benchmark_noinconsistent.bed"
        ],

        HG004: [
            vcf: "deployment/reference/truth/HG004_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG004_GRCh38_1_22_v4.2.1_benchmark_noinconsistent.bed"
        ],

        HG005: [
            vcf: "deployment/reference/truth/HG005_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG005_GRCh38_1_22_v4.2.1_benchmark.bed"
        ],

        HG006: [
            vcf: "deployment/reference/truth/HG006_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG006_GRCh38_1_22_v4.2.1_benchmark.bed"
        ],

        HG007: [
            vcf: "deployment/reference/truth/HG007_GRCh38_1_22_v4.2.1_benchmark.vcf.gz",
            bed: "deployment/reference/truth/HG007_GRCh38_1_22_v4.2.1_benchmark.bed"
        ]
    ]

    // =====================================================
    // SEQC2 SOMATIC TRUTH REGISTRY (clinical benchmarking)
    // =====================================================
    somatic_truth = [

        // SEQC2 Tumor-Normal reference (HCC1395 / HCC1395BL)
        SEQC2: [

            truth_snv_vcf : "deployment/reference/seqc2/SEQC2_highconf_sSNV.vcf.gz",
            truth_indel_vcf : "deployment/reference/seqc2/SEQC2_highconf_sINDEL.vcf.gz",

            highconf_bed : "deployment/reference/seqc2/SEQC2_highconf_regions.bed",

            strat_dir : "deployment/reference/seqc2/stratifications"
        ]
    ]

    // =====================================================
    // SOMATIC / SEQC2 (future use)
    // =====================================================
    pon         = null
    pon_tbi     = null

    // =====================================================
    // OUTPUT
    // =====================================================
    outfolder   = 'results'
    runID       = "${new Date().format('yyyyMMdd_HHmmss')}"
}


// =====================================================
// PROCESS SETTINGS
// =====================================================
process {

    executor       = 'local'
    errorStrategy  = 'terminate'
    maxRetries     = 1

    withLabel: 'qc' {
        container = 'qc.sif'
    }

    withLabel: 'gatk' {
        container = 'core.sif'
        cpus      = 4
        memory    = '16 GB'
        time      = '12h'
    }

    withLabel: 'benchmark' {
        container = 'happy.sif'
        cpus      = 8
        memory    = '32 GB'
        time      = '24h'
    }
}


// =====================================================
// CONTAINER PROFILE
// =====================================================
profiles {

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "$HOME/.singularity"
    }
}


// =====================================================
// REPORTING (clinical traceability)
// =====================================================
timeline { enabled = true }
report   { enabled = true }
trace    { enabled = true }
dag      { enabled = true }

process {

    // -------------------------------------------------
    // TASK CLASSES (semantic, not numeric)
    // -------------------------------------------------

    withLabel: 'tiny' {
        cpus   = 1
        memory = 2.GB
        time   = '1h'
    }

    withLabel: 'small' {
        cpus   = 2
        memory = 6.GB
        time   = '4h'
    }

    withLabel: 'medium' {
        cpus   = 4
        memory = 16.GB
        time   = '12h'
    }

    withLabel: 'large' {
        cpus   = 8
        memory = 32.GB
        time   = '24h'
    }

    withLabel: 'xlarge' {
        cpus   = 16
        memory = 64.GB
        time   = '36h'
    }

    withLabel: 'xxlarge' {
        cpus   = 32
        memory = 128.GB
        time   = '48h'
    }
}